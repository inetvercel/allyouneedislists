# Sanity Project Config
# Get these from https://sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity Write Token (for import script only — never expose this publicly)
# Create at: Sanity Manage → API → Tokens → Add API Token (Editor role)
SANITY_WRITE_TOKEN=your_write_token_here

# OpenAI API Key (for AI post generation pipeline — content + fallback images)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Ideogram API Key (BEST for featured images — embeds title text in image, $0.08/image)
# Get at: https://ideogram.ai/api
# Used by: node scripts/generate-post.mjs --image=ideogram
IDEOGRAM_API_KEY=your_ideogram_key_here

# Unsplash Access Key (free real photos, 5000 req/hour)
# Get at: https://unsplash.com/developers → New Application
# Used by: node scripts/generate-post.mjs --image=unsplash
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
